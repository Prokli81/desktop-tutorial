{
  "name": "sklad-warehouse",
  "version": "1.0.0",
  "private": true,
  "description": "Sklad — склад мебели и техники (Android APK)",
  "scripts": {
    "copy:web": "node copy-web.mjs",
    "cap:sync": "npm run copy:web && npx cap sync android",
    "cap:open": "npx cap open android",
    "android:add": "npx cap add android",
    "android:apk": "cd android && gradlew.bat assembleDebug"
  },
  "capacitor": {
    "platforms": [
      "android"
    ]
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0"
  }
}
