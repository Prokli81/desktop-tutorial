{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "📱 Flutter: запустить на телефоне",
      "type": "shell",
      "command": "flutter run",
      "options": {
        "cwd": "${workspaceFolder}/sklad_flutter"
      },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "📦 Flutter: собрать APK",
      "type": "shell",
      "command": "flutter build apk --debug",
      "options": {
        "cwd": "${workspaceFolder}/sklad_flutter"
      },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "💻 Веб: сервер + браузер",
      "dependsOrder": "sequence",
      "dependsOn": ["💻 Веб: сервер", "💻 Веб: открыть браузер"],
      "problemMatcher": []
    },
    {
      "label": "💻 Веб: сервер",
      "type": "shell",
      "command": "python -m http.server 4174",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "💻 Веб: открыть браузер",
      "type": "shell",
      "command": "start http://localhost:4174",
      "windows": {
        "command": "start http://localhost:4174"
      },
      "problemMatcher": []
    },
    {
      "label": "🔄 Обновить с GitHub",
      "type": "shell",
      "command": "git pull",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "⚙️ Один раз: установить Flutter",
      "type": "shell",
      "command": "${workspaceFolder}\\ustanovit-flutter.bat",
      "windows": {
        "command": "${workspaceFolder}\\ustanovit-flutter.bat"
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    }
  ]
}
